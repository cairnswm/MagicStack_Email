### Variables
@baseUrl = http://localhost:3076
@prodUrl = https://email.magicrunez.com
@tenantId = 3515ce3b-164d-11f1-946d-fe88d4cc3569
@apiKey = eff66794-6800-11f1-8237-00505661e513
@hostname = localhost

# ─────────────────────────────────────────────
# POST /send  —  Send an email directly
# ─────────────────────────────────────────────

### Send a plain email
POST {{baseUrl}}/send
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-APIKEY: {{apiKey}}
X-Hostname: {{hostname}}

{
  "subject": "Hello from Three To Focus Email",
  "htmlBody": "<h1>Hello!</h1><p>This is a test email.</p>",
  "to": [
    { "email": "cairnswm@gmail.com" }
  ],
  "cc": [],
  "bcc": []
}

### PRODUCTION SEND

POST {{prodUrl}}/send
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-APIKEY: {{apiKey}}
X-Hostname: {{hostname}}

{
  "subject": "Hello from Three To Focus Email",
  "htmlBody": "<h1>Hello!</h1><p>This is a test email.</p>",
  "to": [
    { "email": "cairnswm@gmail.com" }
  ],
  "cc": [],
  "bcc": []
}

### Send email with a userId recipient
POST {{baseUrl}}/send
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-APIKEY: {{apiKey}}
X-Hostname: {{hostname}}

{
  "subject": "Welcome to Three To Focus Email",
  "htmlBody": "<p>Your account is ready.</p>",
  "to": [
    { "userId": "44" }
  ]
}
