# Send Email (direct)
# Description: Sends an email directly with subject, htmlBody, and recipients.
# Creates email, email_recipient, email_attachment, email_image, and email_event records.
# Delivers synchronously or queues based on tenant email_delivery_mode property.

@baseUrl = http://localhost:3097
@tenantId = f63421a5-f5b2-11f0-937d-1a220d8ac2c9
@apiKey = your-api-key
@hostname = localhost

### Send email (direct)
POST {{baseUrl}}/send
Content-Type: application/json
X-Tenant-ID: {{tenantId}}
X-APIKEY: {{apiKey}}
X-Hostname: {{hostname}}

{
  "subject": "Welcome to MagicStack",
  "htmlBody": "<h1>Hello!</h1><p>Welcome to MagicStack.</p>",
  "to": [
    { "emailAddress": "recipient@example.com" }
  ],
  "cc": [],
  "bcc": [],
  "attachments": [],
  "images": []
}
